# Copy this file to .env and fill in real values. Do NOT commit .env.

# Server
PORT=5000
NODE_ENV=development

# CORS: the URL where the React client runs
CLIENT_URL=http://localhost:5173

# PostgreSQL connection
# Local dev: use the individual variables below.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sports_hub
DB_USER=postgres
DB_PASSWORD=your_password_here

# Cloud/production (Vercel, Render, etc.): set a single connection string.
# When DATABASE_URL is set it is used instead of the DB_* vars (with SSL).
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=1d
